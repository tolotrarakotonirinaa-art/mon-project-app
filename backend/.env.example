APP_NAME="DevEnviron 4D"
APP_ENV=local
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Base de données (désactivée pour l'instant - Phase 1)
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=devenviron
# DB_USERNAME=postgres
# DB_PASSWORD=

# JWT
JWT_SECRET=GENERATE_WITH_php_artisan_jwt_secret
JWT_TTL=1440
JWT_REFRESH_TTL=20160

# CORS - Frontend React
FRONTEND_URL=http://localhost:5173

# Cache (file pour phase 1, redis plus tard)
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync
